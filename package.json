{
  "name": "jyutjyu-mcp",
  "version": "1.0.0",
  "description": "MCP server for Jyutjyu Cantonese Dictionary - 粵語辭叢 MCP 服務器",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "jyutjyu-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cantonese",
    "dictionary",
    "jyutping",
    "粵語",
    "廣東話",
    "詞典"
  ],
  "author": "jyutjyucom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jyutjyucom/jyutjyu-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/jyutjyucom/jyutjyu-mcp/issues"
  },
  "homepage": "https://github.com/jyutjyucom/jyutjyu-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "execa": "^9.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3"
  }
}
